    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chill-institute/contracts.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0"
  }
}
