{
  "name": "@chill-institute/contracts",
  "version": "0.1.4",
  "description": "Canonical protobuf API contracts and generated client artifacts for Chill",
  "license": "MIT",
  "packageManager": "pnpm@10.15.1",
  "type": "module",
  "sideEffects": false,
  "files": [
    "gen/ts",
    "proto",
    "README.md",
    "LICENSE"
